{
    "installCommand": "pip install -r requirements.txt --break-system-packages",
    "buildCommand": "python manage.py collectstatic --noinput && python manage.py migrate",
    "functions": {
        "api/index.py": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api/index.py"
        }
    ]
}
